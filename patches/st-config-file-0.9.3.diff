 static uint buttons; /* bit field of pressed buttons */
 
+static int show_welcome_msg = 0;
+
+void
+welcome_msg(void)
+{
+	// Clear screen and print welcome message
+	const char *msg = "printf \'\\033[H\\033[2J\' && "
+		"printf \'  ****************** \\033[1mWelcome to Simple Terminal+ (st+)\\033[0m *******************\' && echo && "
+		"printf \'  ◆ Default configuration file has been generated in: \\033[1m~/.st.conf\\033[0m\' && echo && "
+		"printf \'  ◆ To configure st+ and install nerd-fonts, run: \\033[1m$APPDIR/st-config\\033[0m\' && echo && "
+		"printf \'  ◆ To uninstall st+ and related files, run: \\033[1m$APPDIR/st-config uninstall\\033[0m\' && echo && "
+		"printf \'  ************************************************************************\' && echo \n";
+	ttywrite(msg, strlen(msg), 1);
+}
+
+void
+load_config(void)
+{
+	FILE *fp;
+	char path[256];
+	char line[256];
+	char results[128];
+	unsigned char n;
+
+	// Open and read config file
+	const char *home = getenv("HOME");
+	if (!home) return;
+	snprintf(path, sizeof(path), "%s/.st.conf", home);
+	fp = fopen(path, "r");
+
+	// Build config file if missing
+	if (!fp) {
+		show_welcome_msg = 1;
+		fp = fopen(path, "w");
+		if (!fp) return;
+		fprintf(fp, "font=\"%s\"\n", font);
+		fprintf(fp, "rows=\"%d\"\n", rows);
+		fprintf(fp, "cols=\"%d\"\n", cols);
+		fprintf(fp, "alpha=\"%f\"\n", alpha);
+		for (n=0; n<16; n++)
+			fprintf(fp, "colorname[%d]=\"%s\"\n", n, colorname[n]);
+		fprintf(fp, "defaultfg=\"%d\"\n", defaultfg);
+		fprintf(fp, "defaultbg=\"%d\"\n", defaultbg);
+		fprintf(fp, "defaultcs=\"%d\"\n", defaultcs);
+		fprintf(fp, "defaultrcs=\"%d\"\n", defaultrcs);
+		fclose(fp);
+		return;
+	}
+
+	// Scan configuration values
+	while (fgets(line, sizeof(line), fp)) {
+		if (sscanf(line, "font=\"%127[^\"]\"", results) == 1) {
+			font = xmalloc(strlen(results) + 1);
+			strcpy(font, results);
+		}
+		else if (sscanf(line, "rows=\"%5[^\"]\"", results) == 1)
+			rows = strtol(results, NULL, 10);
+		else if (sscanf(line, "cols=\"%5[^\"]\"", results) == 1)
+			cols = strtol(results, NULL, 10);
+		else if (sscanf(line, "alpha=\"%5[^\"]\"", results) == 1)
+			alpha = strtof(results, NULL);
+		else if (sscanf(line, "colorname[%d]=\"%7[^\"]\"", &n, results) == 2) {
+			if (n<16) {
+				colorname[n] = xmalloc(7);
+				strncpy(colorname[n], results, 7);
+			}
+		}
+		else if (sscanf(line, "defaultfg=\"%3[^\"]\"", results) == 1)
+			defaultfg = strtol(results, NULL, 10);
+		else if (sscanf(line, "defaultbg=\"%3[^\"]\"", results) == 1)
+			defaultbg = strtol(results, NULL, 10);
+		else if (sscanf(line, "defaultcs=\"%3[^\"]\"", results) == 1)
+			defaultcs = strtol(results, NULL, 10);
+		else if (sscanf(line, "defaultrcs=\"%3[^\"]\"", results) == 1)
+			defaultrcs = strtol(results, NULL, 10);
+	}
+
+	// Overwrite options and close file
+	fclose(fp);
+	return;
+}
